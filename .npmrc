# =============================================================
# .npmrc - npm Supply Chain Security Hardening
# =============================================================

# --- Registry Pinning (対策: Dependency Confusion) ---
# 全インストールを公式レジストリに強制する
# プライベートパッケージを使う場合はスコープ付きレジストリを追加:
#   @mycompany:registry=https://npm.pkg.github.com
registry=https://registry.npmjs.org/

# --- Install Scripts無効化 (対策: 悪意のあるinstallフック) ---
# preinstall/postinstallスクリプトの自動実行を防止する
# スクリプトが必要なパッケージ(esbuild, sharp等)は
# package.jsonの "allowedScripts" で明示的に許可する
ignore-scripts=true

# --- Lockfile強制 ---
# package-lock.jsonを常に生成・尊重する
package-lock=true

# --- インストール時の脆弱性監査 ---
audit=true
audit-level=critical

# --- Strict SSL (レジストリへのMITMを防止) ---
strict-ssl=true

# --- LockfileからレジストリURLを除去 (対策: Lockfile Poisoning) ---
# resolved URLが不正なレジストリを指すことを防ぐ
omit-lockfile-registry-resolved=true

# --- クールダウン (対策: 侵害されたメンテナ / 悪意のある新バージョン) ---
# パッケージ公開から指定日数以内のバージョンをインストール対象から除外する
# コミュニティが悪意のあるコードを検出・報告する時間的猶予を確保
# npm 11.10.0以降で利用可能
# 参考: https://yamory.io/blog/supplychain-attack-on-axios
min-release-age=7

# --- オフラインキャッシュ優先 (攻撃の窓口を縮小) ---
prefer-offline=true

# --- fundingメッセージ無効化 (ノイズ削減) ---
fund=false
